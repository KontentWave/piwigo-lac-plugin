# Ignore everything by default
/*

# Keep specific root files
!/index.php
!/ageconsent.css
!/legal_clause.css
!/legal_clause.html
!/.gitignore
!/.gitmodules

# Allow albums/plugins path chain
!/albums/
!/albums/plugins/

# Ignore all plugins by default (only direct children)
/albums/plugins/*

# UNIGNORE the LAC plugin (tracked in main repo)
!/albums/plugins/lac/
!/albums/plugins/lac/**

# Allow the submodule mount point (directory only)
!/albums/plugins/core_privacy_toggle
