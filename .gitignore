# Ignore everything by default
/*

# Keep specific root files
!/index.php
!/ageconsent.css
!/legal_clause.css
!/legal_clause.html
!/.gitignore
!/.gitmodules

# Allow albums path
!/albums/

# Ignore EVERYTHING under albums by default
/albums/**

# Re-allow plugins directory
!/albums/plugins/

# Track LAC plugin fully (part of main repo)
!/albums/plugins/lac/
!/albums/plugins/lac/**

# Allow submodule mount point (directory entry only)
!/albums/plugins/core_privacy_toggle
