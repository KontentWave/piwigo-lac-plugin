# Ignore everything by default
/*

# Keep specific root files
!/index.php
!/ageconsent.css
!/legal_clause.css
!/legal_clause.html
!/.gitignore
!/.gitmodules

# Allow albums + plugins trees
!/albums/
!/albums/plugins/

# Ignore everything under plugins by default (recursive)
/albums/plugins/**

# UNIGNORE the LAC plugin (tracked in the main repo)
!/albums/plugins/lac/
!/albums/plugins/lac/**

# UNIGNORE the submodule mount-point (so we can add it)
/albums/plugins/core_privacy_toggle/**    # ignore contents by default
!/albums/plugins/core_privacy_toggle      # but allow the directory itself

